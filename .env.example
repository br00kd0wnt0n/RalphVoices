# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ralph_voices

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Cloudflare R2 (object storage for uploaded creative assets)
# Set ENABLE_R2_STORAGE=true to route uploaded images/PDFs to R2 instead of
# storing base64 inside Postgres JSONB. R2_PUBLIC_URL is the public bucket
# domain used to construct fetchable URLs (e.g. https://assets.example.com).
ENABLE_R2_STORAGE=false
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ralph-voices-assets
R2_PUBLIC_URL=

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Auth
# JWT_SECRET MUST be set to a strong random value. The server refuses to boot
# with the literal default 'development-secret-change-me' unless you also set
# NODE_ENV=development AND ALLOW_INSECURE_JWT=true.
JWT_SECRET=your-secret-key-change-in-production
ALLOW_INSECURE_JWT=false

# Demo mode — when true, requests with no Authorization header are silently
# logged in as demo@ralphvoices.com. MUST be false in any client-facing or
# shared deployment.
ENABLE_DEMO_MODE=false

# GWI Spark integration — dormant by default. Flip to true and supply
# GWI_API_KEY to reactivate when the commercial agreement is in place.
ENABLE_GWI=false
GWI_API_KEY=

# Optional retention policy. When set to a positive integer N, completed tests
# older than N days are auto-archived (status=archived) and their uploaded
# assets are nulled out. Test metadata + scoring results are preserved. Unset
# (default) = no expiry.
TEST_RETENTION_DAYS=

# Optional Ralph Context Base mirror — set both to forward completed tests.
RCB_URL=
RCB_API_KEY=

# Narrativ (Brainstorm) return-signal webhook. When a test that originated
# from a Narrativ handoff (?source=narrativ&session_id=...) completes,
# notifyNarrativ() in routes/tests.ts fires a HMAC-signed POST back to
# {NARRATIV_BASE_URL}/api/voices/callback. The secret MUST be byte-identical
# to the same env var on the Narrativ Railway project. Empty/unset on
# either side = no callback is sent (safe default).
NARRATIV_VOICES_WEBHOOK_SECRET=
NARRATIV_BASE_URL=
